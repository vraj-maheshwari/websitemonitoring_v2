FLASK_ENV=development
FLASK_DEBUG=1

# Database
DATABASE_URL=sqlite:///website_monitor.db

# Redis
REDIS_URL=redis://default:tqJqMQBXOXaodaHqpErIvJYPZIkLNsQU@redis.railway.internal:6379

# Alert thresholds
RESPONSE_TIME_THRESHOLD=3.0       # seconds
SSL_EXPIRY_WARNING_DAYS=7

# Enable real Core Web Vitals collection via Playwright.
# Set to false on servers with < 1GB RAM or no display server.
# When false, the existing proxy estimates from cwv_estimator.py are used.
LIGHTHOUSE_ENABLED=true

# Email (mock for now)
ALERT_EMAIL=admin@example.com
